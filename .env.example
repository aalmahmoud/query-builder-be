# Local environment for query-builder-be.
# Copy to .env and fill in the secrets:  cp .env.example .env
#
# docker-compose reads this file automatically for the Postgres container.
# To use it for the app in IntelliJ, paste these into the Run Configuration's
# "Environment variables" (or install the EnvFile plugin and point it at .env).

# --- Database (shared by docker-compose and the app) ---
# The database name is fixed to query_builder_db (see application.properties).
DB_USERNAME=qb
DB_PASSWORD=qb

# --- Required secrets: the app refuses to start without these ---
# JWT signing key (HS256). Minimum 32 bytes. Generate:
#   openssl rand -base64 48
JWT_SECRET=

# AES-256 / HMAC key for column-level PII encryption (national_id).
# Must decode to EXACTLY 32 bytes. Generate:
#   openssl rand -base64 32
APP_ENCRYPTION_KEY=

# --- Optional tuning (defaults shown; uncomment to override) ---
# Access-token lifetime in ms (default 24h). 900000 = 15 min.
#JWT_EXPIRATION_MS=86400000
# Refresh-token lifetime in ms (default 7 days).
#JWT_REFRESH_EXPIRATION_MS=604800000
# Login rate limit per IP.
#LOGIN_RATE_LIMIT_CAPACITY=5
#LOGIN_RATE_LIMIT_REFILL_SECONDS=60
# Dev SQL logging.
#SPRING_JPA_SHOW_SQL=false
#HIBERNATE_FORMAT_SQL=false
# CORS allow-list (prod profile only; comma-separated origins).
#CORS_ALLOWED_ORIGINS=https://app.example.com
